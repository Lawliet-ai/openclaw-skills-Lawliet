{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Hive-Commander Configuration Schema",
  "type": "object",
  "properties": {
    "session": {
      "type": "object",
      "properties": {
        "api_key": { "type": "string" },
        "base_url": { "type": "string", "format": "uri" },
        "model": { "type": "string" }
      },
      "required": ["api_key", "base_url", "model"]
    },
    "workers": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "role": { "type": "string" },
          "prompt": { "type": "string" },
          "query": { "type": "string" }
        },
        "required": ["id", "role", "prompt", "query"]
      }
    }
  },
  "required": ["session", "workers"]
}
